# Vim shortcut {{{
alias v='vim'
# }}}

# Live log output {{{
alias log='tail -f'
# }}}

# List five most-recently modified files {{{
alias ls5='ls -1t | head -5'
# }}}

# Bundler {{{
alias b='bundle'
alias bi='b install'
alias bu='b update'
alias be='b exec'
# }}}

# Rails {{{
alias rc='be rails console'
alias rs='be rails server'
alias rg='be rails generate'
alias rdb='be rails dbconsole'
# }}}
